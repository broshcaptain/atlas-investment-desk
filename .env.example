# Bu dosyayı .env olarak kopyalayın ve kendi değerlerinizle doldurun.
# .env, .gitignore'da olduğu için repoya commit edilmez.

# PostgreSQL bağlantı adresi (prod). Yerelde farklı bir DB için değiştirin
# (örn. test için: sqlite:///./atlas_dev.db)
DATABASE_URL=postgresql+psycopg2://atlas:atlas@localhost:5432/atlas
